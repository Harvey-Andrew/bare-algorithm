{
  "name": "harvey-andrew",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:analyze": "cross-env ANALYZE=true next build --webpack",
    "bundle:snapshot:before": "node scripts/bundle-snapshot.mjs before",
    "bundle:snapshot:after": "node scripts/bundle-snapshot.mjs after",
    "bundle:analyze:before": "npm run build:analyze && npm run bundle:snapshot:before",
    "bundle:analyze:after": "npm run build:analyze && npm run bundle:snapshot:after",
    "bundle:compare": "node scripts/bundle-compare-visualize.mjs",
    "bundle:refresh:compare": "npm run bundle:analyze:after && npm run bundle:compare",
    "start": "next start",
    "predev": "pnpm run generate:problem-loaders && pnpm run generate:search-data",
    "prebuild": "pnpm run generate:problem-loaders && pnpm run generate:search-data",
    "generate:search-data": "node scripts/generate-search-data.mjs",
    "generate:problem-loaders": "node scripts/generate-problem-loaders.mjs",
    "validate:content": "node scripts/validate-content-consistency.mjs && pnpm run check:dirs",
    "validate:content:strict": "node scripts/validate-content-consistency.mjs --strict && pnpm run check:dirs",
    "check:dirs": "node scripts/check-directories.mjs",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "pnpm run test:unit",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:unit:report": "node -e \"require('fs').mkdirSync('test-results/vitest',{recursive:true})\" && vitest run --coverage --reporter=default --reporter=json --outputFile=test-results/vitest/results.json",
    "test:e2e:smoke": "node -e \"require('fs').mkdirSync('test-results/playwright',{recursive:true})\" && playwright test --grep @smoke",
    "test:report:visualize": "node scripts/test-report-visualize.mjs",
    "test:workflow": "pnpm run test:unit:report && pnpm run test:e2e:smoke && pnpm run test:report:visualize",
    "perf:drilldown": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\perf-interactive-drilldown.ps1 -OutDir docs/performance/drilldown -Port 3000 -Url /problems/array/two-sum",
    "perf:drilldown:headed": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\perf-interactive-drilldown.ps1 -OutDir docs/performance/drilldown -Port 3000 -Url /problems/array/two-sum -Headed",
    "perf:report:visualize": "node scripts/perf-report-visualize.mjs",
    "perf:full": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\perf-lighthouse.ps1 -OutDir docs/performance/baseline -Port 3000 && powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\perf-lighthouse.ps1 -OutDir docs/performance/optimized -Port 3000 && pnpm run perf:report:visualize && pnpm run perf:drilldown",
    "security:audit": "node scripts/security-audit.mjs",
    "security:audit:ci": "node scripts/security-audit.mjs --ci",
    "oss:export": "node scripts/export-oss.mjs",
    "oss:export:skip-validate": "node scripts/export-oss.mjs --skip-validate",
    "prepare": "husky",
    "commit": "git-cz",
    "ci:all": "pnpm run lint && pnpm run validate:content && pnpm run test:workflow && pnpm run security:audit && pnpm run perf:full"
  },
  "config": {
    "commitizen": {
      "path": "node_modules/cz-git"
    }
  },
  "dependencies": {
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tailwindcss/typography": "^0.5.19",
    "@vercel/analytics": "^1.6.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.23.26",
    "katex": "^0.16.27",
    "lucide-react": "^0.562.0",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.1",
    "rehype-katex": "^7.0.1",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "remark-toc": "^9.0.0",
    "tailwind-merge": "^3.4.0",
    "tailwindcss-animate": "^1.0.7",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2",
    "@ianvs/prettier-plugin-sort-imports": "^4.7.0",
    "@next/bundle-analyzer": "^16.1.6",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@vitest/coverage-v8": "^4.0.18",
    "commitizen": "^4.3.1",
    "cross-env": "^10.1.0",
    "cz-git": "^1.12.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "jsdom": "27.0.1",
    "lint-staged": "^16.2.7",
    "playwright-core": "^1.58.2",
    "prettier": "^3.7.4",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "vitest": "^4.0.18"
  },
  "pnpm": {
    "overrides": {
      "minimatch@^3.0.0": "3.1.5",
      "lodash@^4.0.0": "4.17.23",
      "tmp@^0.0.33": "0.2.4",
      "ajv@^6.0.0": "6.14.0",
      "ajv@^8.0.0": "8.18.0"
    },
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "unrs-resolver"
    ]
  },
  "packageManager": "pnpm@10.30.3+sha512.c961d1e0a2d8e354ecaa5166b822516668b7f44cb5bd95122d590dd81922f606f5473b6d23ec4a5be05e7fcd18e8488d47d978bbe981872f1145d06e9a740017"
}
