# App
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# GitHub Personal Access Token (server-side only, for discussion count + issue creation)
# Requires `public_repo` scope (or broader repo scope for private repos)
# GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Optional: override issue target repository
# GITHUB_ISSUE_REPO=owner/repo
# Optional: issue API rate limiting (defaults: 3/minute, 20/day per IP)
# ISSUE_RATE_LIMIT_MAX_PER_MINUTE=3
# ISSUE_RATE_LIMIT_MAX_PER_DAY=20

# Optional: Cloudflare Turnstile for issue submission anti-bot
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x4AAAAAxxxxxxxxxxxxxxxxxxxxxx
# TURNSTILE_SECRET_KEY=0x4AAAAAxxxxxxxxxxxxxxxxxxxxxx

# giscus / GitHub Discussions
# NEXT_PUBLIC_GISCUS_REPO=owner/repo
# NEXT_PUBLIC_GISCUS_REPO_ID=R_kgDOExample
# NEXT_PUBLIC_GISCUS_CATEGORY=Problem Comments
# NEXT_PUBLIC_GISCUS_CATEGORY_ID=DIC_kwDOExample4CsdA
# NEXT_PUBLIC_GISCUS_LANG=zh-CN

# Optional analytics
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Playwright / E2E
# PLAYWRIGHT_BASE_URL=http://127.0.0.1:3001
# PLAYWRIGHT_SKIP_WEBSERVER=1
# NO_PROXY=127.0.0.1,localhost
