{
  "copy": {
    "excludeTopLevel": ["dist", "tmp"]
  },
  "removePaths": [".agents"],
  "problemExport": {
    "mode": "allowlist",
    "allowlist": {
      "array": ["two-sum", "move-zeroes", "subarray-sum-equals-k"],
      "hash-table": ["group-anagrams"],
      "union-find": ["longest-consecutive-sequence"],
      "two-pointers": ["container-with-most-water", "3sum"],
      "monotonic-stack": ["trapping-rain-water"],
      "string": ["longest-substring-without-repeating-characters", "find-all-anagrams-in-a-string"]
    },
    "removeApplicationsJson": true,
    "removeTheoryJson": false,
    "removeCategoryBarrelFiles": true,
    "dropEmptyGuidedStages": true,
    "preserveProblemMetadata": true
  }
}
